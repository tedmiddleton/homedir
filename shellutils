[[ -n "$BASH_VERSION" ]] && export BASH_SILENCE_DEPRECATION_WARNING=1

if [[ -n "$BASH_VERSION" ]]; then
    HISTCONTROL=ignoreboth
    HISTFILESIZE=2000
    shopt -s histappend
    shopt -s extglob
elif [[ -n "$ZSH_VERSION" ]]; then
    setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE APPEND_HISTORY SHARE_HISTORY
    SAVEHIST=2000
    zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'
fi
HISTSIZE=1000  # shared variable, works in both

if [[ -n "$BASH_VERSION" ]]; then
    PROMPT_COMMAND="${PROMPT_COMMAND:+$PROMPT_COMMAND$'\n'}history -a; history -c; history -r"
fi

pathadd() {
    if [[ -d $1 && ! ":$PATH:" =~ ":$1:" ]]; then
        export PATH="${PATH:+"$PATH:"}$1"
    fi
}

# This is unconditional because presumably we're doing this because we WANT it
# to come first no matter what.
pathpreadd() {
    if [[ -d $1 ]]; then
        export PATH="$1${PATH:+":$PATH"}"
    fi
}

ldlibpathadd() {
    if [[ -d $1 && ! ":$LD_LIBRARY_PATH:" =~ ":$1:" ]]; then
        export LD_LIBRARY_PATH="${LD_LIBRARY_PATH:+"$LD_LIBRARY_PATH:"}$1"
    fi
}

pythonpathadd() {
    if [[ -d $1 && ! ":$PYTHONPATH:" =~ ":$1:" ]]; then
        export PYTHONPATH="${PYTHONPATH:+"$PYTHONPATH:"}$1"
    fi
}

# User specific environment
pathadd "$HOME/.local/bin"
pathadd "$HOME/bin"
pathadd "$HOME/.cargo/bin"

#export GOPATH=$HOME/Dropbox/Projects/go

export EDITOR=nvim
export VISUAL=nvim
export CLICOLOR=1

export PYTHON_BASIC_REPL=1

alias la='ls -laF'
alias rm='rm -i'
alias grep='grep --color'
alias grepc='grep --color=always'
alias less='less -Ri'
alias bc='bc -l'


# .inputrc will do this, but later, and key-bindings.bash depends on this
set -o vi


# Completions and keybindings (bash, fzf, git, ...)
if [[ -n "$BASH_VERSION" ]]; then

    # fzf
    if command -v fzf &>/dev/null; then
        if [[ $(fzf --version 2>/dev/null | cut -d. -f2) -ge 48 ]]; then
            eval "$(fzf --bash)"
        else
            for f in /usr/share/fzf/shell/key-bindings.bash \
                     /usr/share/doc/fzf/examples/key-bindings.bash; do
                [[ -f "$f" ]] && source "$f" && break
            done
            [[ -f /usr/share/doc/fzf/examples/completion.bash ]] && \
                source /usr/share/doc/fzf/examples/completion.bash
        fi
    fi

    # everything else
    for file in /opt/homebrew/etc/bash_completion.d/*; do
        [[ -f "$file" ]] && source "$file"
    done

elif [[ -n "$ZSH_VERSION" ]]; then

    # fzf - we know we'll never have an old version
    command -v fzf &>/dev/null && source <(fzf --zsh)

    # everything else
    fpath=(/opt/homebrew/share/zsh/site-functions $fpath)
    source "$HOME/homedir/shellutils_compinit.zsh"
fi


# If the openai key exists, get it
if [[ -f "$HOME/.openai" ]]; then
  while IFS='=' read -r key value; do
    if [[ "$key" == "OPENAI_API_KEY" ]]; then
      export OPENAI_API_KEY="$value"
    fi
  done < "$HOME/.openai"
fi


if [[ -f "$HOME/.anthropic" ]]; then
  while IFS='=' read -r key value; do
    if [[ "$key" == "ANTHROPIC_API_KEY" ]]; then
      export ANTHROPIC_API_KEY="$value"
    fi
  done < "$HOME/.anthropic"
fi
  
# zsh equivalents of having an .inputrc, which we don't because zsh doesn't use
# libreadline.

if [[ -n "$ZSH_VERSION" ]]; then

    # set bell-style none
    unsetopt BEEP

    # set completion-ignore-case on
    zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

    # set show-all-if-ambiguous on  (list completions on first Tab, don't ring
    # bell)
    setopt NO_LIST_BEEP
    zstyle ':completion:*' menu select

    # set show-all-if-unmodified on  (same idea — show list immediately)
    # Covered by the above; zsh doesn't distinguish these two cases separately.

    # set editing-mode vi
    # set keymap vi-insert
    bindkey -v

    # "df": "\e" - typing 'df' in insert mode acts as Escape (switches to normal mode)
    bindkey -M viins 'df' vi-cmd-mode

fi



